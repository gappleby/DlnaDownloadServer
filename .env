# IP address of your Fetch TV box
FETCH_HOST=10.0.0.14

# DLNA port — Fetch TV uses 49152, only change if yours differs
FETCH_PORT=49152

# Where downloaded files are written on the host
OUTPUT_DIR=./recordings

# Name shown in the browser title and page header
APP_NAME=Fetch TV Downloader

# Sub-path prefix when running behind a reverse proxy (e.g. /fetchtv)
# Leave empty when running at the root
ROOT_PATH=
